<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard — Wow Meta Analyzer</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, sans-serif; background: #f3f4f6; color: #111827; line-height: 1.5; }
    .wrap { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
    .nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
    .nav h1 { font-size: 1.5rem; font-weight: 700; }
    .nav a { font-size: .85rem; color: #2563eb; text-decoration: none; }
    .nav a:hover { text-decoration: underline; }

    .card { background: #fff; border: 1px solid #e5e7eb; border-radius: .75rem; overflow: hidden; margin-bottom: 1.5rem; }
    .card-header { padding: .75rem 1.25rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: space-between; }
    .card-header h2 { font-size: .95rem; font-weight: 600; color: #1f2937; }
    .card-header .badge { font-size: .8rem; color: #6b7280; }

    .sync-banner { padding: 1rem 1.25rem; font-size: .85rem; color: #374151; display: flex; gap: .5rem; flex-wrap: wrap; }
    .sync-banner .tag { display: inline-block; padding: .15rem .5rem; border-radius: .25rem; font-size: .75rem; font-weight: 600; }
    .tag-green  { background: #dcfce7; color: #166534; }
    .tag-yellow { background: #fef9c3; color: #854d0e; }
    .tag-red    { background: #fee2e2; color: #991b1b; }
    .tag-blue   { background: #dbeafe; color: #1e40af; }

    table { width: 100%; font-size: .85rem; border-collapse: collapse; }
    thead tr { border-bottom: 1px solid #f3f4f6; }
    th { padding: .6rem 1.25rem; text-align: left; font-size: .7rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: .04em; }
    th.r { text-align: right; }
    td { padding: .55rem 1.25rem; border-bottom: 1px solid #f9fafb; }
    td.r { text-align: right; }
    td.mono { font-family: ui-monospace, monospace; font-size: .8rem; }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: #f9fafb; }

    .bar-track { width: 100%; height: .5rem; background: #e5e7eb; border-radius: .25rem; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: .25rem; transition: width .3s; }
    .bar-green  { background: #22c55e; }
    .bar-yellow { background: #eab308; }
    .bar-red    { background: #ef4444; }
    .bar-blue   { background: #3b82f6; }

    .pct { font-weight: 600; font-size: .8rem; }
    .pct-green  { color: #16a34a; }
    .pct-yellow { color: #ca8a04; }
    .pct-red    { color: #dc2626; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    @media (max-width: 900px) { .grid-3, .grid-4 { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 700px) { .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; } }

    .section-title { font-size: .8rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: .06em; margin: 2rem 0 .75rem; }

    /* Leaderboard distribution */
    .dot { display: inline-block; width: .7rem; height: .7rem; border-radius: 50%; flex-shrink: 0; }
    .role-tag { display: inline-block; padding: .1rem .3rem; border-radius: .2rem; font-size: .6rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; margin-left: .3rem; vertical-align: middle; }
    .role-dps    { background: #fee2e2; color: #991b1b; }
    .role-healer { background: #dcfce7; color: #166534; }
    .role-tank   { background: #dbeafe; color: #1e40af; }
    .spec-row { display: flex; align-items: center; gap: .5rem; padding: .45rem .75rem; border-bottom: 1px solid #f3f4f6; }
    .spec-row:last-child { border-bottom: none; }
    .spec-row:hover { background: #f9fafb; }
    .spec-name { font-size: .8rem; font-weight: 500; min-width: 7rem; }
    .spec-class { font-size: .72rem; color: #9ca3af; min-width: 6rem; }
    .spec-bar-wrap { flex: 1; height: .4rem; background: #e5e7eb; border-radius: .2rem; overflow: hidden; min-width: 3rem; }
    .spec-bar-fill { height: 100%; border-radius: .2rem; transition: width .3s; }
    .spec-counts { font-family: ui-monospace, monospace; font-size: .72rem; color: #6b7280; white-space: nowrap; min-width: 6rem; text-align: right; }
    .spec-pct { font-family: ui-monospace, monospace; font-size: .75rem; font-weight: 600; min-width: 3rem; text-align: right; color: #374151; }
    .class-header { display: flex; align-items: center; gap: .5rem; padding: .6rem .75rem; border-bottom: 1px solid #e5e7eb; }
    .class-header-name { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; }
    .class-header-count { margin-left: auto; font-size: .75rem; color: #6b7280; font-family: ui-monospace, monospace; }
    .shuffle-spec-bar { flex: 1; height: .35rem; background: #e5e7eb; border-radius: .2rem; overflow: hidden; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="nav">
      <h1>Dashboard</h1>
      <a href="/avo">Back to Avo</a>
    </div>

    <% if @season.nil? %>
      <div class="card"><div class="sync-banner">No active season found.</div></div>
    <% else %>

      <%# ── Sync status ── %>
      <div class="card">
        <div class="card-header">
          <h2><%= @season.display_name %></h2>
          <% if @last_cycle %>
            <span class="tag <%= cycle_tag_class(@last_cycle.status) %>"><%= @last_cycle.status.titleize %></span>
          <% end %>
        </div>
        <% if @last_cycle %>
          <div class="sync-banner">
            Last sync: <%= time_ago_in_words(@last_cycle.completed_at || @last_cycle.updated_at) %> ago
            &mdash;
            <%= @last_cycle.completed_character_batches %>/<%= @last_cycle.expected_character_batches %> batches
          </div>
        <% end %>
      </div>

      <%# ── Entry Processing ── %>
      <div class="section-title">Entry Processing</div>

      <div class="grid-2">
        <% @brackets.each do |b| %>
          <div class="card">
            <div class="card-header">
              <h2><%= b[:label] %></h2>
              <span class="badge"><%= b[:regions] %> &mdash; <%= number_with_delimiter(b[:total]) %></span>
            </div>
            <table>
              <thead><tr><th>Status</th><th class="r">Count</th><th class="r">%</th><th style="width:35%">Progress</th></tr></thead>
              <tbody>
                <% b[:rows].each_with_index do |row, i| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="r mono"><%= number_with_delimiter(row[:count]) %></td>
                    <td class="r pct <%= pct_class(row[:pct], good: i == 0) %>"><%= row[:pct] %>%</td>
                    <td><div class="bar-track"><div class="bar-fill <%= bar_class(row[:pct], good: i == 0) %>" style="width:<%= row[:pct] %>%"></div></div></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>

      <%# ── Characters + Freshness ── %>
      <div class="grid-2">
        <% if @characters %>
          <div class="card">
            <div class="card-header">
              <h2>Characters</h2>
              <span class="badge"><%= number_with_delimiter(@characters[:total]) %> unique</span>
            </div>
            <table>
              <thead><tr><th>Status</th><th class="r">Count</th><th class="r">%</th><th style="width:35%">Progress</th></tr></thead>
              <tbody>
                <% @characters[:rows].each_with_index do |row, i| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="r mono"><%= number_with_delimiter(row[:count]) %></td>
                    <td class="r pct <%= pct_class(row[:pct], good: i == 0) %>"><%= row[:pct] %>%</td>
                    <td><div class="bar-track"><div class="bar-fill <%= bar_class(row[:pct], good: i == 0) %>" style="width:<%= row[:pct] %>%"></div></div></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>

        <% if @freshness %>
          <div class="card">
            <div class="card-header">
              <h2>Freshness</h2>
              <span class="badge"><%= number_with_delimiter(@freshness[:total]) %> entries</span>
            </div>
            <table>
              <thead><tr><th>Age</th><th class="r">Count</th><th class="r">%</th><th style="width:35%">Progress</th></tr></thead>
              <tbody>
                <% @freshness[:rows].each_with_index do |row, i| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="r mono"><%= number_with_delimiter(row[:count]) %></td>
                    <td class="r pct <%= pct_class(row[:pct], good: i == 0) %>"><%= row[:pct] %>%</td>
                    <td><div class="bar-track"><div class="bar-fill <%= bar_class(row[:pct], good: i == 0) %>" style="width:<%= row[:pct] %>%"></div></div></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>

      <%# ── Translations ── %>
      <div class="section-title">Translation Coverage</div>

      <% @translations.each do |section| %>
        <div class="card">
          <div class="card-header">
            <h2><%= section[:label] %></h2>
            <span class="badge"><%= section[:total] %> records</span>
          </div>
          <table>
            <thead><tr><th>Locale</th><th class="r">Translated</th><th class="r">Missing</th><th class="r">Coverage</th><th style="width:30%">Progress</th></tr></thead>
            <tbody>
              <% section[:locales].each do |stat| %>
                <tr>
                  <td class="mono"><%= stat[:locale] %></td>
                  <td class="r" style="color:#16a34a"><%= stat[:present] %></td>
                  <td class="r <%= 'pct-red' if stat[:missing] > 0 %>">
                    <%= stat[:missing] > 0 ? stat[:missing] : "&mdash;".html_safe %>
                  </td>
                  <td class="r pct <%= pct_class(stat[:pct]) %>"><%= stat[:pct] %>%</td>
                  <td><div class="bar-track"><div class="bar-fill <%= bar_class(stat[:pct]) %>" style="width:<%= stat[:pct] %>%"></div></div></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <%# ── Leaderboard Distribution ── %>
      <% if @leaderboard %>

        <%# Standard brackets: 2v2, 3v3, rbg %>
        <% if @leaderboard[:regular].any? %>
          <div class="section-title">Spec Distribution — Standard Brackets</div>

          <% @leaderboard[:regular].each do |bracket| %>
            <div class="card" style="margin-bottom:1rem">
              <div class="card-header">
                <h2 style="text-transform:uppercase;letter-spacing:.05em"><%= bracket[:bracket] %></h2>
                <span class="badge"><%= bracket[:regions] %> &mdash; <%= number_with_delimiter(bracket[:total]) %> entries</span>
              </div>
              <% bracket[:specs].each do |spec| %>
                <div class="spec-row">
                  <span class="dot" style="background:<%= spec[:color] %>"></span>
                  <span class="spec-name">
                    <%= spec[:spec_slug].titleize %>
                    <span class="role-tag role-<%= spec[:role] %>"><%= spec[:role] %></span>
                  </span>
                  <span class="spec-class"><%= spec[:class_slug].titleize %></span>
                  <div class="spec-bar-wrap">
                    <div class="spec-bar-fill" style="width:<%= spec[:pct] %>%;background:<%= spec[:color] %>99"></div>
                  </div>
                  <span class="spec-counts">US <%= number_with_delimiter(spec[:us]) %> / EU <%= number_with_delimiter(spec[:eu]) %></span>
                  <span class="spec-pct"><%= spec[:pct] %>%</span>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <%# Solo Shuffle: grouped by class, 4 cards per row %>
        <% if @leaderboard[:shuffle].any? %>
          <div class="section-title">Spec Distribution — Solo Shuffle</div>

          <div class="grid-4" style="margin-bottom:1.5rem">
            <% @leaderboard[:shuffle].each do |class_slug, specs| %>
              <% class_color = specs.first&.dig(:color) || "#9ca3af" %>
              <% class_total = specs.sum { |s| s[:total] } %>
              <div class="card">
                <div class="class-header" style="border-left:3px solid <%= class_color %>">
                  <span class="dot" style="background:<%= class_color %>"></span>
                  <span class="class-header-name" style="color:<%= class_color %>"><%= class_slug.titleize %></span>
                  <span class="class-header-count"><%= number_with_delimiter(class_total) %></span>
                </div>
                <% specs.each do |spec| %>
                  <div class="spec-row">
                    <span class="spec-name" style="min-width:0;flex:1">
                      <%= spec[:spec_slug].titleize %>
                      <span class="role-tag role-<%= spec[:role] %>"><%= spec[:role] %></span>
                    </span>
                    <div class="shuffle-spec-bar">
                      <div class="spec-bar-fill" style="width:<%= class_total > 0 ? (spec[:total].to_f / class_total * 100).round(1) : 0 %>%;background:<%= spec[:color] %>99"></div>
                    </div>
                    <span class="spec-pct" style="min-width:2.5rem"><%= number_with_delimiter(spec[:total]) %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

      <% end %>

    <% end %>
  </div>
</body>
</html>
