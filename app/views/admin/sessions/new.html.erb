<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Login</title>
    <style>
      body { font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #f5f5f5; }
      form { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.1); min-width: 280px; }
      h2 { margin: 0 0 1.5rem; font-size: 1.2rem; }
      input[type=password] { width: 100%; padding: .5rem; margin: .5rem 0 1rem; box-sizing: border-box; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; }
      button { width: 100%; padding: .6rem; background: #1a1a1a; color: white; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
      .alert { color: #c00; margin-bottom: 1rem; font-size: .9rem; }
    </style>
  </head>
  <body>
    <form action="<%= admin_login_path %>" method="post">
      <h2>Admin Access</h2>
      <% if flash[:alert] %><p class="alert"><%= flash[:alert] %></p><% end %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <label for="admin_password">Password</label>
      <input type="password" name="password" placeholder="Password" autofocus>
      <button type="submit">Sign in</button>
    </form>
  </body>
</html>
